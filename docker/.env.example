# BlueQuirk production stack configuration. Copy to `.env` and fill in real values.
# NEVER commit the real .env.

# --- Public URLs ---
SITE_DOMAIN=bluequirk.shop
PUBLIC_SITE_URL=https://bluequirk.shop
# Same-origin API path (Caddy proxies /api to the backend).
PUBLIC_API_URL=https://bluequirk.shop/api

# --- Database (MariaDB, the only datastore) ---
DB_NAME=blue-quirk-db
DB_USER=blue-quirk-user
DB_PASSWORD=change-me-strong
DB_ROOT_PASSWORD=change-me-stronger

# --- Authentication (native Identity Domain) ---
# Long random secret; stretched to a 512-bit HMAC key. Generate with:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret

# One-time admin bootstrap. After the admin exists you may blank these.
AUTH_ADMIN_EMAIL=admin@bluequirk.shop
AUTH_ADMIN_PASSWORD=change-me-strong-admin-password

# --- Email (Resend) — for verification + password-reset emails ---
RESEND_API_KEY=
