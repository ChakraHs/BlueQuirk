# BlueQuirk reverse proxy. Caddy terminates TLS (automatic Let's Encrypt) and
# routes the storefront + API under one origin, so the browser makes same-origin
# calls and CORS is a non-issue in production.
#
# Replace bluequirk.shop with your domain. For local testing use `localhost`
# (Caddy issues a local CA cert).

{$SITE_DOMAIN:localhost} {
	# API and uploaded media go to the backend.
	handle /api/* {
		reverse_proxy backend:9090
	}
	handle /uploads/* {
		reverse_proxy backend:9090
	}

	# Everything else is the Next.js frontend.
	handle {
		reverse_proxy frontend:3000
	}

	encode gzip zstd

	# Baseline security headers. Tune the CSP to your asset/domains before enabling
	# it in enforce mode; it is the main XSS mitigation for the SPA.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}
