# BlueQuirk MariaDB tuning (mounted read-only at /etc/mysql/conf.d).
# Tune innodb_buffer_pool_size to your VPS RAM (rule of thumb: ~50–70% of the
# memory you allocate to the DB container via MARIADB_MEM_LIMIT).

[mysqld]
# UTF-8 everywhere (emoji-safe) — applies to all databases/tables created after.
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# Connections + performance.
max_connections = 200
innodb_buffer_pool_size = 256M
innodb_flush_log_at_trx_commit = 1
innodb_file_per_table = 1

# Containers connect by service name; skipping DNS reverse lookups is faster and
# avoids auth hangs on hosts without reverse DNS.
skip-name-resolve

[client]
default-character-set = utf8mb4

[mysql]
default-character-set = utf8mb4
