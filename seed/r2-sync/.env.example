# Cloudflare R2 credentials — copy this file to `.env` and fill in the values.
# Get these from the Cloudflare dashboard once R2 is active:
#   R2 → Overview → "Manage R2 API Tokens" → Create API token (Object Read & Write)
# The token page shows the Access Key ID + Secret Access Key (secret is shown ONCE).

R2_ACCOUNT_ID=ce4c0a53b2a22e6106a593962344ab49
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=bluequirk-media

# Cloudflare API token — ONLY needed for `npm run sync:api`, the fallback that
# uploads through api.cloudflare.com instead of the S3 endpoint (use it when the
# network blocks <account>.r2.cloudflarestorage.com with a TLS handshake error).
# Create at: My Profile -> API Tokens -> Create Token, with permission
#   Account -> Workers R2 Storage -> Edit.  This is NOT the S3 access key/secret.
CLOUDFLARE_API_TOKEN=

# Public base URL for the bucket (no trailing slash). After you enable the
# bucket's public access you get a "Public r2.dev" URL, e.g.
#   https://pub-xxxxxxxxxxxxxxxx.r2.dev
R2_PUBLIC_BASE=

# Local DB (defaults match docker compose; usually no need to change).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=blue-quirk-user
DB_PASSWORD=blue-quirk-pass-!
DB_NAME=blue-quirk-db
