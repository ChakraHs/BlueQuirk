# =============================================================================
# BlueQuirk — production environment. Copy to .env and fill in real values:
#     cp .env.example .env && nano .env
# NEVER commit the real .env (it is git-ignored).
#
# Variables marked (REQUIRED) must be set or `docker compose up` fails fast.
# =============================================================================

# --- Public URLs / TLS -------------------------------------------------------
# Your domain (A/AAAA record must point at this server's public IP). Caddy uses
# it to obtain a Let's Encrypt certificate automatically. Use "localhost" to
# test locally (Caddy issues a self-signed local CA cert instead).
SITE_DOMAIN=bluequirk.shop                        # (REQUIRED)
# Email Let's Encrypt uses for expiry notices (recommended, optional).
ACME_EMAIL=admin@bluequirk.shop
# Public origins. The API is same-origin (Caddy proxies /api to the backend),
# so browsers make same-origin calls and CORS is a non-issue in production.
PUBLIC_SITE_URL=https://bluequirk.shop            # (REQUIRED)
PUBLIC_API_URL=https://bluequirk.shop/api         # (REQUIRED)

# --- Database (MariaDB — the only datastore) ---------------------------------
# Generate strong values, e.g.:  openssl rand -base64 24
DB_NAME=bluequirk                                 # (REQUIRED)
DB_USER=bluequirk                                 # (REQUIRED)
DB_PASSWORD=change-me-strong                       # (REQUIRED)
DB_ROOT_PASSWORD=change-me-stronger                # (REQUIRED)

# --- Authentication (native Identity Domain) ---------------------------------
# Long random secret, stretched to a 512-bit HMAC key. Generate with:
#     openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret       # (REQUIRED)
# One-time admin bootstrap. After the admin exists you may blank these.
AUTH_ADMIN_EMAIL=admin@bluequirk.shop
AUTH_ADMIN_PASSWORD=change-me-strong-admin-password

# --- Email (Resend) — verification + password-reset mails --------------------
RESEND_API_KEY=

# --- Todify print-on-demand (optional) ---------------------------------------
TODIFY_ENABLED=false
TODIFY_API_TOKEN=
TODIFY_WEBHOOK_SECRET=

# --- Logging (optional; quiet defaults) --------------------------------------
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO

# --- Container memory limits (optional; tune to your VPS) ---------------------
MARIADB_MEM_LIMIT=1g
BACKEND_MEM_LIMIT=1g
FRONTEND_MEM_LIMIT=512m

# --- Backups (used by docker/scripts/backup.sh) ------------------------------
BACKUP_DIR=./docker/volumes/backups
BACKUP_RETENTION_DAYS=14
